        <li aria-current="page" class="active" style="color: var(--color-text-primary); font-weight: 600;">Descargar YouTube a MP3</li>
      </ol>
    </nav>
  </div>

  <div class="container hero-section">
    <div class="hero-content">
      <h1 class="hero-title">Descargar Videos <span class="text-gradient">YouTube a MP3</span></h1>
      <p class="hero-subtitle">Extrae y descarga el audio de cualquier video de YouTube a formato MP3 de forma gratuita, online y en alta calidad.</p>
    </div>
    
    <%- include('partials/converter', { lang: 'es' }) %>
