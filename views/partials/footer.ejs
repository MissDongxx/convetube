<%
const currentYear = new Date().getFullYear();

// Translation dictionary
const t = {
  es: {
    desc: 'El convertidor de YouTube a MP3 líder por su rapidez, seguridad y facilidad de uso. Convierte y descarga música ilimitada gratis.',
    tools: 'Herramientas',
    legal: 'Legal',
    home: 'Inicio',
    privacy: 'Política de Privacidad',
    terms: 'Términos de Servicio',
    dmca: 'DMCA',
    rights: 'Todos los derechos reservados.',
    contact: 'Contacto',
    email: 'Correo electrónico',
    message: 'Tu mensaje',
    messagePlaceholder: 'Escribe tu comentario o sugerencia...',
    send: 'Enviar mensaje',
    sending: 'Enviando...',
    sent: 'Mensaje enviado. Gracias.',
    failed: 'No se pudo enviar. Escríbenos a info@convetube.com.'
  },
  fr: {
    desc: 'Le convertisseur YouTube vers MP3 leader pour sa rapidité, sa sécurité et sa simplicité. Convertissez et téléchargez de la musique gratuite en illimité.',
    tools: 'Outils',
    legal: 'Légal',
    home: 'Accueil',
    privacy: 'Politique de Confidentialité',
    terms: 'Conditions d\'Utilisation',
    dmca: 'DMCA',
    rights: 'Tous droits réservés.',
    contact: 'Contact',
    email: 'E-mail',
    message: 'Votre message',
    messagePlaceholder: 'Écrivez votre commentaire ou suggestion...',
    send: 'Envoyer',
    sending: 'Envoi...',
    sent: 'Message envoyé. Merci.',
    failed: 'Envoi impossible. Écrivez-nous à info@convetube.com.'
  },
  en: {
    desc: 'A fast, simple YouTube audio converter for MP3 and WAV downloads in your browser.',
    tools: 'Tools',
    legal: 'Legal',
    home: 'Home',
    privacy: 'Privacy Policy',
    terms: 'Terms of Service',
    dmca: 'DMCA',
    rights: 'All rights reserved.',
    contact: 'Contact',
    email: 'Email',
    message: 'Your message',
    messagePlaceholder: 'Write your comment or suggestion...',
    send: 'Send message',
    sending: 'Sending...',
    sent: 'Message sent. Thank you.',
    failed: 'Could not send. Email us at info@convetube.com.'
  }
};

const texts = t[lang] || t.es;
const footerHomeHref = lang === 'fr' ? '/convertir-youtube-vers-mp3/' : lang === 'en' ? '/youtube-to-wav/' : '/';
%>

  </main>

  <footer class="main-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <a href="<%= footerHomeHref %>" class="footer-logo">
          <span class="logo-text">Conve<span class="logo-text-alt">Tube</span></span>
        </a>
        <p class="footer-desc"><%= texts.desc %></p>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-title"><%= texts.tools %></h4>
        <ul class="footer-links">
          <li><a href="/"><%= texts.home %></a></li>
          <li><a href="/convertir-youtube-vers-mp3">Convertir YouTube vers MP3 (FR)</a></li>
          <li><a href="/convertidor-de-youtube-a-mp3">Convertidor de YouTube a MP3 (ES)</a></li>
          <li><a href="/convertidor-mp3-no-tube">Convertidor MP3 No Tube (ES)</a></li>
          <li><a href="/descargar-videos-de-youtube-a-mp3-gratis-online">Descargar YouTube a MP3 (ES)</a></li>
          <li><a href="/descargar-musica-de-youtube">Descargar Música de YouTube (ES)</a></li>
          <li><a href="/youtube-a-wav">YouTube a WAV (ES)</a></li>
          <li><a href="/youtube-to-wav">YouTube to WAV (EN)</a></li>
        </ul>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-title"><%= texts.legal %></h4>
        <ul class="footer-links">
          <li><a href="#privacy"><%= texts.privacy %></a></li>
          <li><a href="#terms"><%= texts.terms %></a></li>
          <li><a href="#dmca"><%= texts.dmca %></a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4 class="footer-title"><%= texts.contact %></h4>
        <a href="mailto:info@convetube.com" class="footer-email">info@convetube.com</a>
        <form class="footer-message-form" action="/api/contact" method="post" data-sending="<%= texts.sending %>" data-sent="<%= texts.sent %>" data-failed="<%= texts.failed %>">
          <label class="footer-field-label" for="footer-email"><%= texts.email %></label>
          <input id="footer-email" name="email" class="footer-input" type="email" autocomplete="email" />
          <input class="footer-honeypot" type="text" name="bot_field" autocomplete="off" tabindex="-1" aria-hidden="true" />

          <label class="footer-field-label" for="footer-message"><%= texts.message %></label>
          <textarea id="footer-message" name="message" class="footer-textarea" rows="3" placeholder="<%= texts.messagePlaceholder %>" required></textarea>

          <button class="footer-submit" type="submit"><%= texts.send %></button>
          <p class="footer-form-status" aria-live="polite"></p>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="container footer-bottom-content">
        <p class="copyright">&copy; <%= currentYear %> ConveTube.com. <%= texts.rights %></p>
        <div class="footer-badges">
          <span class="badge">100% Seguro</span>
          <span class="badge">Sin Registro</span>
          <span class="badge">SSL Encriptado</span>
        </div>
      </div>
    </div>
  </footer>

  <style>
    .main-footer {
      background: #2C2824;
      border-top: 1px solid rgba(212, 200, 188, 0.15);
      padding: 60px 0 30px 0;
      margin-top: auto;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: minmax(220px, 1.4fr) minmax(180px, 1fr) minmax(160px, 0.8fr) minmax(240px, 1.2fr);
      gap: 40px;
      margin-bottom: 40px;
    }

    @media (max-width: 1024px) {
      .footer-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .footer-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }
    }

    .footer-logo {
      text-decoration: none;
      display: inline-block;
      margin-bottom: 16px;
    }

    .footer-logo .logo-text {
      font-size: 1.5rem;
      font-weight: 800;
      color: #F5F0EB;
      letter-spacing: -0.03em;
      font-family: var(--font-family);
    }

    .footer-logo .logo-text-alt {
      background: linear-gradient(135deg, #C4593D 0%, #D4714E 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .footer-desc {
      color: #D4C8BC;
      font-size: 0.9rem;
      max-width: 320px;
      line-height: 1.6;
    }

    .footer-title {
      color: #F5F0EB;
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-family: var(--font-family);
    }

    .footer-links {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 12px;
    }

    .footer-links a {
      color: #D4C8BC;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color var(--transition-fast);
    }

    .footer-links a:hover {
      color: #D4714E;
    }

    .footer-email {
      display: inline-block;
      color: #D4714E;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .footer-email:hover {
      text-decoration: underline;
    }

    .footer-message-form {
      display: flex;
      flex-direction: column;
      gap: 8px;
      max-width: 320px;
    }

    .footer-field-label {
      color: #D4C8BC;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .footer-honeypot {
      display: none !important;
    }

    .footer-input,
    .footer-textarea {
      width: 100%;
      border: 1px solid rgba(212, 200, 188, 0.14);
      background: rgba(245, 240, 235, 0.06);
      color: #F5F0EB;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 0.88rem;
      font-family: var(--font-family);
      outline: none;
      transition: border-color var(--transition-fast), background var(--transition-fast);
    }

    .footer-input:focus,
    .footer-textarea:focus {
      background: rgba(245, 240, 235, 0.09);
      border-color: rgba(212, 113, 78, 0.55);
    }

    .footer-textarea {
      min-height: 86px;
      resize: vertical;
    }

    .footer-textarea::placeholder {
      color: #9C948C;
    }

    .footer-submit {
      align-self: flex-start;
      border: 0;
      background: linear-gradient(135deg, #C4593D 0%, #D4714E 100%);
      color: #FFFFFF;
      border-radius: 999px;
      padding: 10px 18px;
      font-size: 0.88rem;
      font-weight: 700;
      font-family: var(--font-family);
      cursor: pointer;
      transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .footer-submit:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 18px rgba(196, 89, 61, 0.22);
    }

    .footer-submit:disabled {
      opacity: 0.65;
      cursor: wait;
      transform: none;
      box-shadow: none;
    }

    .footer-form-status {
      min-height: 18px;
      color: #D4C8BC;
      font-size: 0.78rem;
      line-height: 1.4;
    }

    .footer-form-status.success {
      color: #96C18F;
    }

    .footer-form-status.error {
      color: #F0A08F;
    }

    .footer-bottom {
      border-top: 1px solid rgba(212, 200, 188, 0.10);
      padding-top: 30px;
    }

    .footer-bottom-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }

    @media (max-width: 640px) {
      .footer-bottom-content {
        flex-direction: column;
        text-align: center;
      }
    }

    .copyright {
      color: #9C948C;
      font-size: 0.85rem;
    }

    .footer-badges {
      display: flex;
      gap: 12px;
    }

    .badge {
      background: rgba(245, 240, 235, 0.06);
      border: 1px solid rgba(212, 200, 188, 0.12);
      color: #D4C8BC;
      font-size: 0.75rem;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 12px;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const contactForm = document.querySelector('.footer-message-form');
      if (!contactForm) return;

      const submitButton = contactForm.querySelector('.footer-submit');
      const status = contactForm.querySelector('.footer-form-status');
      const defaultButtonText = submitButton?.textContent || '';

      contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!submitButton || !status) return;

        submitButton.disabled = true;
        submitButton.textContent = contactForm.dataset.sending || defaultButtonText;
        status.textContent = '';
        status.className = 'footer-form-status';

        try {
          const response = await fetch(contactForm.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(contactForm)))
          });

          if (!response.ok) {
            let details = {};
            try {
              details = await response.json();
            } catch (error) {
              details = {};
            }
            throw new Error(details.error || 'Contact request failed');
          }

          contactForm.reset();
          status.textContent = contactForm.dataset.sent || '';
          status.classList.add('success');
        } catch (error) {
          status.textContent = error.message || contactForm.dataset.failed || '';
          status.classList.add('error');
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = defaultButtonText;
        }
      });
    });
  </script>

  <!-- Client JavaScript -->
  <script src="/js/client.js"></script>
</body>
</html>
