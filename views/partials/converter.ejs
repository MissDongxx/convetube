<%
const translations = {
  es: {
    placeholder: 'Pega el enlace de YouTube aquí... (ej. https://www.youtube.com/watch?v=...)',
    button: 'Convertir',
    invalidUrl: 'Por favor, introduce una URL de YouTube válida.',
    analyzing: 'Analizando enlace...',
    downloading: 'Descargando flujo de audio...',
    converting: 'Convirtiendo a MP3 (320kbps)...',
    finishing: 'Finalizando archivo...',
    ready: '¡Conversión Completada!',
    download: 'Descargar MP3',
    convertAnother: 'Convertir otro vídeo',
    playing: 'Reproduciendo',
    paused: 'Pausado',
    mockTitle: 'YouTube Video Audio',
    mockDuration: '00:00'
  },
  fr: {
    placeholder: 'Collez le lien YouTube ici... (ex. https://www.youtube.com/watch?v=...)',
    button: 'Convertir',
    invalidUrl: 'Veuillez saisir une URL YouTube valide.',
    analyzing: 'Analyse du lien...',
    downloading: 'Téléchargement du flux audio...',
    converting: 'Conversion en MP3 (320kbps)...',
    finishing: 'Finalisation du fichier...',
    ready: 'Conversion Terminée !',
    download: 'Télécharger le MP3',
    convertAnother: 'Convertir une autre vidéo',
    playing: 'Lecture en cours',
    paused: 'Pause',
    mockTitle: 'YouTube Video Audio',
    mockDuration: '00:00'
  }
};

const texts = translations[lang] || translations.es;
%>

<div class="converter-box glass-panel">
  <!-- State 1: Input Form -->
  <div id="state-input" class="converter-state active">
    <form id="convert-form" class="convert-form" novalidate>
      <div class="input-wrapper">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 4C6.68629 4 4 6.68629 4 10C4 13.3137 6.68629 16 10 16C13.3137 16 16 13.3137 16 10C16 6.68629 13.3137 4 10 4ZM2 10C2 5.58172 5.58172 2 10 2C14.4183 2 18 5.58172 18 10C18 11.8487 17.3729 13.551 16.3199 14.9056L21.7071 20.2929C22.0976 20.6834 22.0976 21.3166 21.7071 21.7071C21.317 22.0972 20.6843 22.0976 20.293 21.7075L14.9056 16.3199C13.551 17.3729 11.8487 18 10 18C5.58172 18 2 14.4183 2 10Z" fill="var(--color-text-secondary)"/>
        </svg>
        <input 
          type="url" 
          id="youtube-url" 
          class="input-field" 
          placeholder="<%= texts.placeholder %>" 
          required 
          autocomplete="off"
        />
      </div>
      <button type="submit" class="btn-primary">
        <span><%= texts.button %></span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>
    <p id="error-message" class="error-msg"></p>
  </div>

  <!-- State 2: Loading / Converting -->
  <div id="state-loading" class="converter-state">
    <div class="loading-container">
      <div class="spinner-wrapper">
        <div class="glowing-spinner"></div>
      </div>
      <div class="progress-info">
        <h3 id="loading-status" class="loading-title"><%= texts.analyzing %></h3>
        <div class="progress-bar-container">
          <div id="progress-bar-fill" class="progress-bar-fill"></div>
        </div>
        <p id="progress-percent" class="progress-text">0%</p>
      </div>
    </div>
  </div>

  <!-- State 3: Result / Audio Player -->
  <div id="state-result" class="converter-state">
    <div class="result-container">
      <div class="success-header">
        <div class="success-icon-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 6L9 17L4 12" stroke="var(--color-success)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3><%= texts.ready %></h3>
      </div>

      <div class="video-info-card">
        <div id="video-thumb-container" class="video-thumbnail-placeholder">
          <svg class="music-note-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18V5L21 3V16M9 18C9 19.6569 7.65685 21 6 21C4.34315 21 3 19.6569 3 18C3 16.3431 4.34315 15 6 15C7.65685 15 9 16.3431 9 18ZM21 16C21 17.6569 19.6569 19 18 19C16.3431 19 15 17.6569 15 16C15 14.3431 16.3431 13 18 13C19.6569 13 21 14.3431 21 16Z" stroke="url(#thumb-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="thumb-grad" x1="3" y1="12" x2="21" y2="12" gradientUnits="userSpaceOnUse">
                <stop stop-color="#6366f1" />
                <stop offset="1" stop-color="#ec4899" />
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="video-details">
          <h4 id="video-title" class="video-title-text"><%= texts.mockTitle %></h4>
          <p id="video-channel" class="video-channel">ConveTube MP3 Engine &bull; <%= texts.mockDuration %></p>
        </div>
      </div>

      <!-- Custom Audio Player -->
      <div class="custom-audio-player">
        <audio id="audio-element" preload="none"></audio>
        
        <div class="player-controls">
          <button id="player-play-btn" class="player-btn play" aria-label="Play">
            <svg class="play-svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5V19L19 12L8 5Z" />
            </svg>
            <svg class="pause-svg hidden" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 19H10V5H6V19ZM14 5V19H18V5H14Z" />
            </svg>
          </button>

          <div class="timeline-container">
            <span id="player-time-current" class="time-label">0:00</span>
            <input type="range" id="player-timeline" class="timeline-slider" min="0" max="100" value="0" step="0.1" />
            <span id="player-time-total" class="time-label">0:00</span>
          </div>

          <div class="volume-container">
            <button id="player-volume-btn" class="player-btn volume" aria-label="Mute">
              <svg class="vol-high-svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 9V15H7L12 20V4L7 9H3ZM16.5 12C16.5 10.23 15.48 8.71 14 8V16C15.48 15.29 16.5 13.77 16.5 12ZM14 3.23V5.29C16.89 6.15 19 8.83 19 12C19 15.17 16.89 17.85 14 18.71V20.77C18.01 19.86 21 16.28 21 12C21 7.72 18.01 4.14 14 3.23Z" />
              </svg>
              <svg class="vol-mute-svg hidden" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16.5 12C16.5 10.23 15.48 8.71 14 8V10.88L16.26 13.14C16.41 12.78 16.5 12.4 16.5 12ZM19 12C19 12.9 18.82 13.75 18.48 14.53L19.98 16.03C20.63 14.84 21 13.47 21 12C21 7.72 18.01 4.14 14 3.23V5.29C16.89 6.15 19 8.83 19 12ZM4.27 3L3 4.27L7.73 9H3V15H7L12 20V13.27L16.25 17.52C15.58 18.04 14.83 18.45 14 18.7V20.76C15.38 20.44 16.63 19.79 17.67 18.94L20.73 22L22 20.73L4.27 3ZM12 4L9.91 6.09L12 8.18V4Z" />
              </svg>
            </button>
            <input type="range" id="player-volume-slider" class="volume-slider" min="0" max="1" step="0.05" value="0.8" />
          </div>
        </div>
      </div>

      <div class="result-actions">
        <a id="download-btn" href="#" class="btn-primary download-link-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 16V17C4 18.6569 5.34315 20 7 20H17C18.6569 20 20 18.6569 20 17V16M12 4V14M12 14L8 10M12 14L16 10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span><%= texts.download %></span>
        </a>
        <button id="convert-another-btn" class="btn-reset">
          <%= texts.convertAnother %>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .converter-box {
    padding: 36px;
    margin-top: 40px;
    position: relative;
    overflow: hidden;
  }

  .converter-state {
    display: none;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .converter-state.active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* Form / Input styling */
  .convert-form {
    display: flex;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .convert-form {
      flex-direction: column;
    }
  }

  .input-wrapper {
    position: relative;
    flex-grow: 1;
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    pointer-events: none;
  }

  .input-field {
    padding-left: 48px;
  }

  .error-msg {
    color: var(--color-error);
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 10px;
    min-height: 20px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .error-msg.visible {
    opacity: 1;
  }

  /* Loading State */
  .loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 20px 0;
  }

  .spinner-wrapper {
    position: relative;
    width: 80px;
    height: 80px;
    margin-bottom: 24px;
  }

  .glowing-spinner {
    box-sizing: border-box;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid rgba(99, 102, 241, 0.1);
    border-top-color: #6366f1;
    border-right-color: #ec4899;
    animation: spin 1s linear infinite;
    filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.4));
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .progress-info {
    width: 100%;
    max-width: 400px;
  }

  .loading-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--color-text-primary);
  }

  .progress-bar-container {
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .progress-bar-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #ec4899);
    border-radius: 4px;
    transition: width 0.1s linear;
  }

  .progress-text {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  /* Result State */
  .result-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .success-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .success-icon-badge {
    width: 32px;
    height: 32px;
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-header h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .video-info-card {
    display: flex;
    gap: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 16px;
    align-items: center;
  }

  .video-thumbnail-placeholder {
    width: 100px;
    height: 60px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .music-note-icon {
    width: 24px;
    height: 24px;
  }

  .video-details {
    flex-grow: 1;
    min-width: 0;
  }

  .video-title-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 4px;
  }

  .video-channel {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* Custom Audio Player */
  .custom-audio-player {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 12px 20px;
  }

  .player-controls {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .player-controls {
      flex-direction: column;
      gap: 12px;
      align-items: stretch;
    }
  }

  .player-btn {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .player-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .player-btn.play {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    flex-shrink: 0;
    align-self: center;
  }

  .player-btn.play svg {
    width: 18px;
    height: 18px;
  }

  .timeline-container {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-grow: 1;
  }

  .time-label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    min-width: 32px;
  }

  .timeline-slider {
    flex-grow: 1;
    -webkit-appearance: none;
    appearance: none;
    background: rgba(255, 255, 255, 0.08);
    height: 6px;
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }

  .timeline-slider::-webkit-slider-runnable-track {
    width: 100%;
    height: 6px;
    cursor: pointer;
  }

  .timeline-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 5px rgba(99, 102, 241, 0.5);
    cursor: pointer;
    margin-top: -4px;
    transition: transform var(--transition-fast), background var(--transition-fast);
  }

  .timeline-slider::-webkit-slider-thumb:hover {
    background: #ec4899;
    transform: scale(1.15);
  }

  .volume-container {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 120px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .volume-container {
      align-self: flex-end;
    }
  }

  .player-btn.volume {
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }

  .player-btn.volume svg {
    width: 14px;
    height: 14px;
  }

  .volume-slider {
    -webkit-appearance: none;
    appearance: none;
    background: rgba(255, 255, 255, 0.08);
    height: 4px;
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    width: 100%;
  }

  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-text-secondary);
    cursor: pointer;
  }

  .volume-slider::-webkit-slider-thumb:hover {
    background: #6366f1;
  }

  .hidden {
    display: none !important;
  }

  .result-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .result-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }

  .download-link-btn {
    flex-grow: 1;
    text-decoration: none;
  }

  .btn-reset {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-secondary);
    padding: 12px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    font-family: var(--font-family);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .btn-reset:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.15);
  }
</style>
