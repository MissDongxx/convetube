---
const { currentLang = 'es' } = Astro.props;

const currentYear = new Date().getFullYear();

// Translation dictionary
const t = {
  es: {
    desc: 'El convertidor de YouTube a MP3 líder por su rapidez, seguridad y facilidad de uso. Convierte y descarga música ilimitada gratis.',
    tools: 'Herramientas',
    legal: 'Legal',
    home: 'Inicio',
    conv: 'Convertidor YouTube',
    conv2: 'Convertidor a MP3',
    conv3: 'Convertir Videos a MP3',
    privacy: 'Política de Privacidad',
    terms: 'Términos de Servicio',
    dmca: 'DMCA',
    rights: 'Todos los derechos reservados.'
  },
  fr: {
    desc: 'Le convertisseur YouTube vers MP3 leader pour sa rapidité, sa sécurité et sa simplicité. Convertissez et téléchargez de la musique gratuite en illimité.',
    tools: 'Outils',
    legal: 'Légal',
    home: 'Accueil',
    conv: 'Convertisseur YouTube vers MP3',
    conv2: 'Convertisseur MP3',
    conv3: 'Convertir des Vidéos',
    privacy: 'Politique de Confidentialité',
    terms: 'Conditions d\'Utilisation',
    dmca: 'DMCA',
    rights: 'Tous droits réservés.'
  }
};

const texts = t[currentLang] || t.es;
---

<footer class="main-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href={currentLang === 'es' ? '/' : '/convertir-youtube-vers-mp3/'} class="footer-logo">
        <span class="logo-text">Conve<span class="logo-text-alt">Tube</span></span>
      </a>
      <p class="footer-desc">{texts.desc}</p>
    </div>

    <div class="footer-links-group">
      <h4 class="footer-title">{texts.tools}</h4>
      <ul class="footer-links">
        <li><a href="/">{texts.home}</a></li>
        <li><a href="/convertir-youtube-vers-mp3/">Convertir YouTube vers MP3 (FR)</a></li>
        <li><a href="/convertidor-de-youtube-a-mp3/">Convertidor de YouTube a MP3 (ES)</a></li>
        <li><a href="/convertidor-de-youtube-a-mp3/convertir-videos-de-youtube-a-mp3/">Convertir Videos de YouTube a MP3 (ES)</a></li>
      </ul>
    </div>

    <div class="footer-links-group">
      <h4 class="footer-title">{texts.legal}</h4>
      <ul class="footer-links">
        <li><a href="#privacy">{texts.privacy}</a></li>
        <li><a href="#terms">{texts.terms}</a></li>
        <li><a href="#dmca">{texts.dmca}</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-content">
      <p class="copyright">&copy; {currentYear} ConveTube.com. {texts.rights}</p>
      <div class="footer-badges">
        <span class="badge">100% Seguro</span>
        <span class="badge">Sin Registro</span>
        <span class="badge">SSL Encriptado</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: #08090d;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 60px 0 30px 0;
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  .footer-logo {
    text-decoration: none;
    display: inline-block;
    margin-bottom: 16px;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
  }

  .logo-text-alt {
    background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-desc {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    max-width: 320px;
    line-height: 1.6;
  }

  .footer-title {
    color: var(--color-text-primary);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-links {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 12px;
  }

  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: #6366f1;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 30px;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  @media (max-width: 640px) {
    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }
  }

  .copyright {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-badges {
    display: flex;
    gap: 12px;
  }

  .badge {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 12px;
  }
</style>
